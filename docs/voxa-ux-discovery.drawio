        <mxCell id="u3nsl79MriWC6Fww2i5i-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;strokeColor=light-dark(#666666,#4F4F4F);spacing=5;spacingLeft=5;spacingRight=5;align=left;" value="&lt;span style=&quot;&quot;&gt;The fundamental object in the system. Messages either start a Thread or are replying in a Thread and are organized by Topics, written by Users.&amp;nbsp;&amp;nbsp;&lt;/span&gt;" vertex="1">
